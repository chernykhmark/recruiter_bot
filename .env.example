# Ключ: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Актуальная экономичная модель DeepSeek; при необходимости переопределите.
LLM_MODEL=deepseek/deepseek-v3.2
# Для JSON-оценки резюме reasoning выключен в коде.
LLM_MAX_TOKENS=400
LLM_REQUEST_TIMEOUT_SEC=45
# Последовательная оценка надёжнее для OpenRouter/DeepSeek.
ANALYZER_WORKERS=1
TELEGRAM_TOKEN=123:ABC...
TELEGRAM_CHAT_ID=123456789
# Локальный Shadowsocks только для LLM и Telegram:
SHADOWSOCKS_ENABLED=false
# HTTP-прокси для LLM требует shadowsocks-rust: brew install shadowsocks-rust
SHADOWSOCKS_BINARY=/opt/homebrew/bin/sslocal
SHADOWSOCKS_TELEGRAM_BINARY=/opt/homebrew/bin/ss-local
SHADOWSOCKS_SERVER=server.example.com
SHADOWSOCKS_SERVER_PORT=8388
SHADOWSOCKS_PASSWORD=password
SHADOWSOCKS_METHOD=chacha20-ietf-poly1305
# 0 = выбирать свободный порт при каждом запуске
SHADOWSOCKS_LOCAL_PORT=0
# Необязательный путь к TTF-шрифту с поддержкой кириллицы для PDF.
# На macOS без настройки используется системный Arial.
PDF_FONT_PATH=
# OPENAI_PROXY_URL также поддерживается для обратной совместимости.
OPENROUTER_PROXY_URL=
TELEGRAM_PROXY_URL=
VACANCIES_URL=https://hh.ru/employer/vacancies

CHROME_VERSION_MAIN=<совпадает с версией установленного Chrome!>
CHROME_SESSION_PATH=./chrome_session
CHROME_MANUAL_LOGIN=false

# Первый прогон — на малом объёме:
MAX_RESUMES_PER_VACANCY=5
TOP_N=5
ANALYZER_FILTER_ENABLED=false   # сначала проверяем качество этапа 2 без фильтра

PARSER_DELAY_SEC=1.0            # снижать до 0.3–0.5 после успешного прогона

TELEGRAM_CONNECT_TIMEOUT_SEC=30
TELEGRAM_TIMEOUT_SEC=180
